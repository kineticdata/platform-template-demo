\"]=\" + encodeURIComponent( value ) );\n})\n\n\n// Remove null values from urlParams list\nload.urlParams = load.urlParams.filter(function(val) { return val.split(\"=\")[1]!==\"null\" });\n\nK.load({\n  path: bundle.spaceLocation() + K('kapp').slug()+ '/' + load.formSlug + '?' + load.urlParams.join(\"&\"),\n  container: load.container,\n  loaded: function(form) {\n    var subform = K.as(form);\n    // initialize watch fields definfed in configureation\n    $.each(load.watchFields, function(source, desination){\n      subform('form').$watch(source, function(newVal,oldVal){\n        K('field['+desination+']').value(newVal);\n      });\n    })\n  }\n});"
